DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Set to True only if PostgreSQL is running.
USE_POSTGRES=False
POSTGRES_DB=nextgen_db
POSTGRES_USER=nextgen_user
POSTGRES_PASSWORD=nextgen_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Local/dev safe default (prints email in terminal, no SMTP needed).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=NextGen Solutions <noreply@nextgen.local>
ADMIN_NOTIFICATION_EMAIL=sksajarulhoque@gmail.com

PAYMENTS_ENABLED=False
PAYMENT_CURRENCY=INR
MANUAL_PAYMENT_ENABLED=True
UPI_ID=your_upi_id@bank
UPI_PAYEE_NAME=NextGen Solutions
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
